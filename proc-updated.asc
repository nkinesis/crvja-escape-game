' ==========================================
' Objects Interaction
' ==========================================
Procedure P_INTERACT_POSTER1[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "An Amiga ad poster, coming loose"
   End If
   
   If Key State($17) ' I key
      If HAS_FLOPPY_1 = 1
         CURRENT_TEXT$ = "You have already found the floppy behind it"
      Else If HAS_FLOPPY_1 = 0
         CURRENT_TEXT$ = "There's a floppy disk behind it"
         HAS_FLOPPY_1 = 1
      End If
   End If
      
End Proc

Procedure P_INTERACT_AMIGA_OFF[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   
   If Key State($26)' L key         
      CURRENT_TEXT$ = "The Amiga is Off"
   End If

   If Key State($17) 
      If HAS_DIGICODE = 0 ' I key
         CURRENT_TEXT$ = "It needs power to operate"
      End If
   End If

   If Key State($17) 
      If HAS_DIGICODE = 1 ' I key
         CURRENT_TEXT$ = "You already have the door code"
      End If
   End If

End Proc

Procedure P_INTERACT_AMIGA_ON[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   
   If Key State($26)' L key         
      CURRENT_TEXT$ = "The Amiga is On"
   End If

   If Key State($03) 
      If HAS_AMIGA_MANUAL = 1
         CURRENT_TEXT$ = "You use the manual to understand how to use it"
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 5
         INTERACTION_SUCCESS = 1
      End If
   End If

   If Key State($17)  ' I key
      CURRENT_TEXT$ = "You don’t know how to use it"
   End If

End Proc

Procedure P_INTERACT_PRINTER_ON[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Printer is on"
   End If
   
   If Key State($17)  ' I key
      CURRENT_TEXT$ = "Nothing to print"
   End If

   If Key State($02) 
      If HAS_USB_KEY = 1 
         If HAS_AMIGA_MANUAL = 0
            CURRENT_TEXT$ = "You print the amiga manual"
            HAS_AMIGA_MANUAL = 1
            INTERACTION_SUCCESS = 1
         End If
      End If
   End If
End Proc

Procedure P_INTERACT_PRINTER_OFF[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Printer is off"
   End If

   If Key State($17)  ' I key
      CURRENT_TEXT$ = "It needs power to operate"
   End If
End Proc

Procedure P_INTERACT_POWER_STRIP_ON[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "A power strip, it is switched on"
      End If

      If Key State($17)  ' I key
         CURRENT_TEXT$ = "It is already on"
      End If
End Proc

Procedure P_INTERACT_POWER_STRIP_OFF[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "A power strip, it is switched off"
      End If
      
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "You turned it on"
         map(6,1) = 4
         map(7,1) = 9
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 11
      End If
End Proc


Procedure P_INTERACT_CEILING_FLOPPY[INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y]
    If Key State($26)' L key
        CURRENT_TEXT$ = "there’s a floppy taped on ceiling, it's out of reach"
    End If

    If Key State($17) ' I key
        CURRENT_TEXT$ = "you cannot reach the floppy"
    End If

    If Key State($07) 
      If HAS_CHAIR = 1
         CURRENT_TEXT$ = "you reach the floppy but it fall"
         map(INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y) = 13
         INTERACTION_SUCCESS = 1
      End If
    End If
End Proc

Procedure P_INTERACT_TABLE[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "It is just a table"
   End If

   If HAS_FLOPPY_2 = 0 
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "There’s a floppy disk taped under table"
         HAS_FLOPPY_2 = 1
         HAS_TAPE = 1
         INTERACTION_SUCCESS = 1
      End If   
   End If   
End Proc

Procedure P_INTERACT_CHAIR[INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y]
    If Key State($17) ' I key
      CURRENT_TEXT$ = "you get the chair"
      HAS_CHAIR = 1
      map(INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y) = 0
    End If

    If Key State($26)  ' L key
       CURRENT_TEXT$ = "It is just a chair"
    End If
End Proc

Procedure P_INTERACT_DOOR[INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y]
   If Key State($17) ' I key
      If HAS_DIGICODE = 0  
         CURRENT_TEXT$ = "It does not open"
      Else HAS_DIGICODE = 1
         CURRENT_TEXT$ = "You use the code and escape. Congratulaitons, you win!"
      End If
   End If

   If Key State($26)  ' L key
       CURRENT_TEXT$ = "This door is locked with a digicode"
   End If
End Proc

Procedure P_INTERACT_DESK[INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y]
    If Key State($17) ' I key
      If HAS_USB_KEY = 0  
        CURRENT_TEXT$ = "You find a USB Key"
        HAS_USB_KEY = 1
      End If
    End If

    If Key State($26) ' L key
        CURRENT_TEXT$ = "There's a note on the desk : Amiga manual on USB key"
    End If
End Proc

Procedure P_INTERACT_AMIGA_FLOPPY_1[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Amiga waiting for blue floppy"
   End If

   If Key State($17)  ' I key
      CURRENT_TEXT$ = "You need to insert blue floppy"
   End If

   If Key State($04) 
      If HAS_FLOPPY_1 = 1
         CURRENT_TEXT$ = "Now waiting for green floppy"
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 6
         INTERACTION_SUCCESS = 1
      End If
   End If

End Proc

Procedure P_INTERACT_AMIGA_FLOPPY_2[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Amiga waiting for green floppy"
   End If

   If Key State($17)  ' I key
      CURRENT_TEXT$ = "You need to insert green floppy"
   End If

   If Key State($05) 
      If HAS_FLOPPY_2 = 1
         CURRENT_TEXT$ = "Now waiting for red floppy"
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 7
         INTERACTION_SUCCESS = 1
      End If
   End If
End Proc

Procedure P_INTERACT_AMIGA_FLOPPY_3[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Amiga waiting for red floppy"
   End If

   If Key State($17)  ' I key
      CURRENT_TEXT$ = "You need to insert red floppy"
   End If

   If Key State($06) 
      If HAS_FLOPPY_3 = 1
         CURRENT_TEXT$ = "You get the door code"
         HAS_DIGICODE = 1
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 3
         INTERACTION_SUCCESS = 1
      End If
   End If
End Proc

Procedure P_INTERACT_BROKEN_FLOPPY[INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y]
    If Key State($26)' L key
        CURRENT_TEXT$ = "The floppy is broken on floor"
    End If

    If Key State($17) ' I key
        CURRENT_TEXT$ = "The floppy is broken in two"
    End If

    If Key State($08) 
      If HAS_TAPE = 1 
         If HAS_FLOPPY_3 = 0
            CURRENT_TEXT$ = "You repair the floppy with tape"
            map(INTERACTING_TILE_POSITION_X, INTERACTING_TILE_POSITION_Y) = 0
            HAS_FLOPPY_3 = 1
            INTERACTION_SUCCESS = 1
         End If
      End If
    End If
End Proc
