' README: Amiga Poster, Amiga, Printer, Power Strip procedures


Procedure P_INTERACT_POSTER1[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "There's a floppy disk behind it"
   End If
   
   If Key State($17)  ' I key
      CURRENT_TEXT$ = "There's a floppy disk behind it"
      ' todo: the poster sprite could be changed, to show that it is already opened. 
      ' map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 1
      HAS_FLOPPY_1 = 1
   End If
End Proc


Procedure P_INTERACT_AMIGA_ON_OFF
   POWER_STRIP_POSITION_X = 14
   POWER_STRIP_POSITION_Y = 2

   If map(POWER_STRIP_POSITION_X,POWER_STRIP_POSITION_Y) = 4 ' TODO: 4 is the number of power strip sprite in the OFF state.
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "The Amiga is Off"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "FAIL: The Amiga is Off"
      End If
   Else If
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "The Amiga is On"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "You don’t know how to use it"
      End If
   Else
      If Key State($03)  ' 2 key
         If HAS_AMIGA_MANUAL = 1
            CURRENT_TEXT$ = "The computer works now"
         End If
      End If
   End If
End Proc


Procedure P_INTERACT_AMIGA_FLOPPY_1
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Amiga waiting for floppy 1"
   End If
   If Key State($17)  ' I key
      CURRENT_TEXT$ = "Amiga waiting for floppy 1"
   End If
   If Key State($04)  ' 3 key
      If HAS_FLOPPY_1 = 1
         CURRENT_TEXT$ = "Now waiting for floppy 2"
         ' TODO: we need to change a state here as well!
      End If
   End If
End Proc

Procedure P_INTERACT_AMIGA_FLOPPY_2
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Amiga waiting for floppy 2"
   End If
   If Key State($17)  ' I key
      CURRENT_TEXT$ = "Amiga waiting for floppy 2"
   End If
   If Key State($05)  ' 4 key
      If HAS_FLOPPY_2 = 1
         CURRENT_TEXT$ = "Now waiting for floppy 3"
         ' TODO: we need to change a state here as well!
      End If
   End If
End Proc

Procedure P_INTERACT_AMIGA_FLOPPY_3
   If Key State($26)  ' L key
      CURRENT_TEXT$ = "Amiga waiting for floppy 3"
   End If
   If Key State($17)  ' I key
      CURRENT_TEXT$ = "Amiga waiting for floppy 3"
   End If
   If Key State($06)  ' 5 key
      If HAS_FLOPPY_3 = 1
         CURRENT_TEXT$ = "You get the door code"
         ' TODO: we should track the code somehow!
      End If
   End If
End Proc


Procedure P_INTERACT_POWER_STRIP_ON_OFF
   'TODO: add the "IS_POWER_ON" in the global variables 
   'TODO: add the "IS_AMIGA_ON" in the global variables 
   'TODO: add the "IS_PRINTER_ON" in the global variables 
   If IS_POWER_ON = 0
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "A power strip, it is switched off"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "You turn the Power Strip on"
         IS_POWER_ON = 1
         IS_AMIGA_ON = 1
         IS_PRINTER_ON = 1
      End If
   Else
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "A power strip, it is switched on"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "FAIL: nothing to do here"
         'CURRENT_TEXT$ = "You turn the Power Strip off"
         'IS_POWER_ON = 0
         'IS_AMIGA_ON = 0
         'IS_PRINTER_ON = 0
      End If      
   End If
End Proc


Procedure P_INTERACT_PRINTER_ON_OFF
   'TODO: add the "IS_POWER_ON" in the global variables 
   If IS_POWER_ON = 0
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "Printer is off"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "FAIL: Printer is off"
      End If
   Else
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "Printer is on"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "Nothing to print"
      End If
      If Key State($02)
         If HAS_USB_KEY = 1
            If HAS_AMIGA_MANUAL = 0
               CURRENT_TEXT$ = "You print the amiga manual"
               HAS_AMIGA_MANUAL = 1
            End If
         End If
      End If
   End If
End Proc


Procedure P_INTERACT_TABLE[INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y]
   If map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 7 'Table (floppy under)
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "It is a table"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "There’s a floppy taped under table"
         HAS_FLOPPY_2 = 1
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 11 'Table (tape under)
      End If
   Else If map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 11 'Table (tape under)
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "There’s still tape under the table"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "You unstick the tape"
         HAS_TAPE = 1
         map(INTERACTING_TILE_POSITION_X,INTERACTING_TILE_POSITION_Y) = 12 'Table (tape under)
      End If 
   Else 'Table (nothing)
      If Key State($26)  ' L key
         CURRENT_TEXT$ = "Just a table, nothing more"
      End If
      If Key State($17)  ' I key
         CURRENT_TEXT$ = "FAIL: Just a table, nothing more"
      End If 
   End If
End Proc